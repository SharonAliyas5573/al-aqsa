# Copy this file to .env and fill in your Supabase project values.
# (Vite exposes only variables prefixed with VITE_ to the browser.)

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# WhatsApp notification mode: "mock" (default, no external account needed)
# or "live" (calls the send-whatsapp Supabase Edge Function -> Meta Cloud API).
VITE_WHATSAPP_MODE=mock

# Shop branding shown on receipts/invoices.
VITE_SHOP_NAME=Al Aqsa Tailor Shop
VITE_SHOP_PHONE=+91 00000 00000
VITE_SHOP_ADDRESS=Shop address goes here
